# ============================================================
# CityRenew Agent 后端环境变量示例
# 复制为 backend/.env 后按需修改；.env 不会提交 Git。
# ============================================================

# ---- 应用基础 ----
APP_NAME=CityRenew Agent
APP_VERSION=0.1.0
APP_ENV=development
# 运行模式：eval（默认，严格 train/val/test 隔离与自评可信度） | demo（演示，可选）
APP_MODE=eval

# ---- 服务 ----
API_HOST=0.0.0.0
API_PORT=8000
# 前端来源（CORS），逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- 数据库（SQLite，文件落 backend/data/，已 gitignore）----
DATABASE_URL=sqlite:///./data/cityrenew.db

# ---- 坐标系与圈层口径（对齐 docs/11 决策）----
# 坐标系预留，默认 WGS84，待第2/4阶段确认是否需要转换
COORDINATE_SYSTEM=WGS84
# 圈层口径以报告模板为准：近邻 500m / 辐射 1500m
NEARBY_BUFFER_M=500
RADIATION_BUFFER_M=1500

# ---- 外部大模型（第1-2阶段不启用，仅预留；对齐 docs/11 D3）----
# 默认 mock：不调用任何外部 API、不读取语料、不生成事实数字。
# 第7阶段再决定是否真正启用 deepseek / openai-compatible。
LLM_PROVIDER=mock
LLM_BASE_URL=
# API Key 仅放此处的 .env（非 .env.example），切勿写死在代码或提交 Git
LLM_API_KEY=

# ---- 第10B：合规外部数据源 API Key（仅放 .env，切勿提交 Git）----
# 缺失时对应采集接口返回 not_configured，绝不伪造数据；
# 不绕配额、不突破分页限制、不换账号/IP 突破限制、不做大规模采集。
AMAP_KEY=
BAIDU_MAP_KEY=
TENCENT_MAP_KEY=
# 高德采集限流/样例上限（保护配额）
AMAP_REQUEST_TIMEOUT_S=8
AMAP_RATE_LIMIT_QPS=3.0
AMAP_MAX_PAGES=3
AMAP_PAGE_SIZE=20
